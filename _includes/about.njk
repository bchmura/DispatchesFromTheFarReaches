{% extends "base.njk" %}
{% block content %}
<main class="wrap">
  <div class="about">
    <svg class="stamp-mark" viewBox="0 0 120 120" fill="none" stroke="currentColor" aria-hidden="true">
      <defs><path id="stampring-about" d="M60 60 m-43 0 a43 43 0 1 1 86 0 a43 43 0 1 1 -86 0"/></defs>
      <circle cx="60" cy="60" r="54" stroke-width="1.4"/>
      <circle cx="60" cy="60" r="45" stroke-width="1"/>
      <text><textPath href="#stampring-about" startOffset="0">MISKATONIC UNIVERSITY · SPECIAL COLLECTIONS · </textPath></text>
      <path d="M60 45v30M45 60h30" stroke-width="1"/>
      <path d="M60 49l4 11-4 11-4-11z" fill="currentColor" stroke="none"/>
    </svg>
    <div class="portrait">
      <svg viewBox="0 0 300 375" fill="none" stroke="currentColor" stroke-width="1.2" role="img" aria-label="Placeholder illustrated silhouette portrait">
        <rect width="300" height="375" fill="#0f1109"/>
        <circle cx="150" cy="150" r="60" stroke="#8a6d34" opacity=".8"/>
        <path d="M70 340 Q70 240 150 240 Q230 240 230 340" stroke="#8a6d34" opacity=".8"/>
      </svg>
      <div class="portrait-note">Placeholder — real photo pending</div>
    </div>
    <div>
      <p class="kicker">A Biographical Note</p>
      <h1>{{ title }}</h1>
      <p class="accession">Miskatonic University · Special Collections · Correspondent, uncatalogued</p>
      {{ content | safe }}
      <div class="profile-links">
        <a href="https://www.linkedin.com/in/williambchmura/" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 10v7M8 7.5v.01M12 17v-4.5a2 2 0 014 0V17M12 12.5v4.5"/></svg>
          <span class="plabel">LinkedIn</span>
          <span class="pnote">Professional history</span>
        </a>
        <a href="https://github.com/bchmura" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M8 6L3 12l5 6M16 6l5 6-5 6"/></svg>
          <span class="plabel">GitHub</span>
          <span class="pnote">Code and other artifacts</span>
        </a>
        <a href="/contact/">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/></svg>
          <span class="plabel">Correspondence</span>
          <span class="pnote">Routed, checked irregularly</span>
        </a>
      </div>
    </div>
  </div>
</main>
{% endblock %}

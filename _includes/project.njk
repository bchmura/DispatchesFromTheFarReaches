{% extends "base.njk" %}
{% block content %}
<div class="breadcrumb">
  <div class="wrap"><div class="inner"><a href="/projects/">Projects</a> / {{ title }}</div></div>
</div>
<section class="proj-header">
  <div class="wrap">
  <div class="inner">
    <p class="accession">Miskatonic University · Special Collections · {{ accession }}</p>
    <span class="status status-{{ status | lower }}">{{ status }}</span>
    <h1>{{ title }}</h1>
    <div class="proj-header-body">
      <div class="proj-header-text">
        {{ content | safe }}
      </div>
      <div class="proj-media" style="background:#0f1109;"></div>
    </div>
  </div>
  </div>
</section>
<main class="wrap">
  <div class="proj-content">
    <div class="journal">
      <h2 class="section-head">Journal</h2>
      {% for entry in collections.journalEntriesByProject[page.fileSlug] %}
      <article>
        <a class="stretched-link" href="{{ entry.url }}" aria-hidden="true" tabindex="-1"></a>
        <div class="entry-head">
          <h3>{{ entry.data.title }}</h3>
          <span class="date-hover"><span class="dispatch-no">No. {{ entry.data.no }}</span> · {{ entry.date | date("d MMMM yyyy") }}</span>
        </div>
        {{ entry.templateContent | firstParagraph | safe }}
        <div class="entry-actions"><a href="{{ entry.url }}">View this journal entry</a></div>
      </article>
      {% endfor %}
    </div>
    <aside class="resources">
      <h2 class="section-head">Resources</h2>
      <ul>
        {% for r in resources %}
        <li><a href="{{ r.url }}"><span class="rtitle">{{ r.title }}</span><span class="rnote">{{ r.note }}</span></a></li>
        {% endfor %}
      </ul>
    </aside>
  </div>
</main>
{% endblock %}

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
{# Fonts are self-hosted (@font-face rules at the top of site.css, files in
   assets/fonts/ — see docs/fonts.md). Preload only the three faces every
   page renders with; italics, latin-ext, and Kalam (Mermaid-only) download
   on demand via their @font-face unicode-range. `crossorigin` is required
   on font preloads even for same-origin files, or the preload is refetched. #}
<link rel="preload" href="/assets/fonts/im-fell-english-400-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/eb-garamond-400-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/fragment-mono-400-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="stylesheet" href="/assets/css/site.css" />
<link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed.xml" />
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
<meta name="theme-color" content="#14150f">
{% extends "base.njk" %}
{% block content %}
<main class="wrap">
  <div class="contact-head">
    <p class="kicker">Filed Correspondence</p>
    <h1>{{ title }}</h1>
    {{ content | safe }}
  </div>
  <div class="thankyou-panel">
    <div class="seal-panel">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
        <circle cx="50" cy="50" r="36"/>
        <circle cx="50" cy="50" r="27"/>
      </svg>
      <p><strong>No. — received</strong>Logged the moment it arrived. A reply follows in due course, whatever the correspondent's current expedition allows.</p>
    </div>
    <p><a href="/">&larr; Return to the front page</a></p>
  </div>
</main>
{% endblock %}
